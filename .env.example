# Money Dev Kit — Lightning paywall (server only)
# Generate via: npx @moneydevkit/create --webhook-url=$APP_URL
# Use printf, not echo, when setting these manually — trailing newlines silently break MDK auth.
MDK_ACCESS_TOKEN=
MDK_MNEMONIC=

# Public base URL where MDK delivers webhooks to this app.
# Dev: ngrok / cloudflared tunnel pointing at localhost:3000.
# Prod: your deployed Vercel domain.
# Update via: npx @moneydevkit/create --webhook-url=$APP_URL  (creates new creds)
# MDK auto-appends /api/mdk — provide the base URL only.
APP_URL=

# Supabase (call logging — Phase 6)
# URL + anon key are NEXT_PUBLIC_ for client-side reads on /dashboard.
# Service-role key is server-only — NEVER prefix it with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstream API providers — services degrade gracefully when blank.
# - GOOGLE_PLACES_API_KEY: required for /api/v1/search/places (returns
#   a fixture when blank). Get one at console.cloud.google.com →
#   Maps Platform → Places API.
# - NEVERBOUNCE_API_KEY (or ZEROBOUNCE_API_KEY): optional — boosts
#   /api/v1/validate/email accuracy via the upstream provider's SMTP
#   check. Skip cleanly when blank; local MX + syntax + disposable
#   checks still cover ~80% of NeverBounce's value without a key.
GOOGLE_PLACES_API_KEY=
NEVERBOUNCE_API_KEY=
ZEROBOUNCE_API_KEY=
